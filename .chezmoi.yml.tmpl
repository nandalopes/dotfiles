{{- $bin := promptString "my_bin_dir" -}}
{{- $fuck := promptString "thefuck" -}}
{{- $basic_ipv4 := promptString "Base_do_IPv4" -}}
{{- $gpgkey := promptString "GPGKEY" -}}
data:
  ipv4:
    base: "{{ default "10.0.10" $basic_ipv4 }}"
    mask: "{{ default "10.0.10" $basic_ipv4 }}.0/24"
  lang_mozilla: "
    {{- eq .chezmoi.hostname "home-PC-N" | ternary "en-US" "pt-BR" -}}
  "
  my_bin_dir: "{{ default "$HOME/bin" $bin | expandenv }}"
  screen:
    redshift:
      global: redshift
      program: redshift
      adjustment:
        method: randr
        comment: |
          ; Set the adjustment-method: 'randr', 'vidmode'.
          ; 'randr' is the preferred method, 'vidmode' is an older API that
          ; works in some cases when 'randr' does not.
          ; type 'redshift -m list' to see all possible values.
    gammastep:
      global: general
      program: gammastep
      adjustment:
        method: randr
        comment: |
          ; Set the adjustment-method: 'randr', 'vidmode', 'drm', 'wayland'.
          ; 'randr' is the preferred X11 method, 'vidmode' is an older API that
          ; works in some cases when 'randr' does not.
          ; type 'gammastep -m list' to see all possible values.
  thefuck: "{{ default "please" $fuck }}"
  what_gui: "{{ eq .chezmoi.hostname "home-PC-N" | ternary "qt" "gtk" }}"
# diff:
#   format: git
edit:
  # command: gvim
encryption: gpg
gpg:
  recipient: {{ default "B24CB540944A918E" $gpgkey }}
  args:
    - --quiet
sourceDir: "{{ .chezmoi.sourceDir }}"
