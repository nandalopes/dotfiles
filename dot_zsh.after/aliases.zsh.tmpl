docker-stop-all() {
  docker ps --all | awk 'NR > 1 {print $1}' | \
    xargs -r docker rm
}

docker-clean() {
  docker ps --all | awk 'NR > 1 {print $1}' | \
    xargs --no-run-if-empty docker rm
  docker images | awk 'NR > 1 {print $3}' | \
    xargs --no-run-if-empty docker rmi
}

