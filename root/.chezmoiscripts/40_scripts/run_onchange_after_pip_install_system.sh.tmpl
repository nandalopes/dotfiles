{{- /*
  vim:ft=bash.gotmpl:
  */ -}}

#!/usr/bin/env bash

# -e: exit on error
set -e


{{- $reqPath := joinPath .chezmoi.homeDir ".backup/install/pip/system.txt" }}
{{- if stat $reqPath }}
# {{ include $reqPath | sha1sum }}
echo '# Install system pips...'
sudo pip3 install \
  --isolated \
  --prefix /usr/local \
  --upgrade \
  --upgrade-strategy only-if-needed \
  --requirement {{ $reqPath }}
{{- end }}

