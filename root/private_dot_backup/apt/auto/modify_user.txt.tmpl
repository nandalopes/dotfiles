  {{- $initialStatus := "/var/log/installer/initial-status.gz" -}}
  {{- if stat $initialStatus -}}

#!/bin/sh

echo "# {{ .chezmoi.osRelease.prettyName }}"

LC_COLLATE=C.UTF-8

comm -23 \
<(apt-mark showauto | sort -u) \
<(gzip -dc {{ $initialStatus }} | sed -n 's/^Package: //p' | sort -u)

  {{- end }}
